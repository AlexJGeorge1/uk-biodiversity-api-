DB_HOST=localhost          # Hostname of the PostgreSQL server
DB_PORT=5432              # PostgreSQL port (default: 5432)
DB_NAME=biodiversity      # Name of the database to connect to
DB_USER=your_mac_username # PostgreSQL role (on macOS/Homebrew this is your Mac username)
DB_PASSWORD=              # Password for the PostgreSQL role (often empty on local Homebrew installs)

OPENAI_API_KEY=sk-...     # OpenAI API key for AI-generated ecological insights
